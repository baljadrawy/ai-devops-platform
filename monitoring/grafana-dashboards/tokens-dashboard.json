{
  "dashboard": {
    "title": "AI Agent - Token Usage & Cache",
    "panels": [
      {
        "title": "💰 Token Usage Over Time",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(ai_agent_tokens_used_total[5m])",
            "legendFormat": "Tokens/min"
          }
        ]
      },
      {
        "title": "📊 Cache Hit Rate",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "(ai_agent_cache_hits_total / (ai_agent_cache_hits_total + ai_agent_cache_misses_total)) * 100",
            "legendFormat": "Cache Hit %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 50, "color": "yellow" },
                { "value": 80, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "title": "💸 Cost Savings",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "ai_agent_tokens_saved_total * 0.000003",
            "legendFormat": "USD Saved"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": { "mode": "thresholds" }
          }
        }
      },
      {
        "title": "🔧 Tools Usage",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum by (tool) (ai_agent_tool_calls_total)"
          }
        ]
      }
    ],
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" }
  }
}
